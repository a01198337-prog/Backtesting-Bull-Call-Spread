# Packages
import numpy as np
import pandas as pd
import yfinance as yf
import plotly.express as px
from scipy.stats import norm

# Parameters
tenor_days = 126
T = tenor_days / 252

buy_call_strike = 1.055
sell_call_strike = 1.328

stock_basket = ['AAPL', 'MSFT', 'PANW']

risk_free_rate = 0.04
dividend_yield = 0.00

vol_window = 126

# Download stock prices
data = yf.download(stock_basket, period='5y', interval='1d', auto_adjust=True)

close_data = data['Close']

# Daily returns
daily_returns = close_data.pct_change()

# Rolling annualized volatility
rolling_vol = daily_returns.rolling(vol_window).std() * np.sqrt(252)

# Strike prices
K1 = close_data * buy_call_strike
K2 = close_data * sell_call_strike

# Final price after 126 trading days
ST = close_data.shift(-tenor_days)

# Black-Scholes function
def black_scholes_call(S, K, r, q, sigma, T):
    d1 = (np.log(S / K) + (r - q + 0.5 * sigma**2) * T) / (sigma * np.sqrt(T))
    d2 = d1 - sigma * np.sqrt(T)

    call_price = S * np.exp(-q * T) * norm.cdf(d1) - K * np.exp(-r * T) * norm.cdf(d2)

    return call_price

# Daily Black-Scholes premiums
call_K1 = black_scholes_call(
    S=close_data,
    K=K1,
    r=risk_free_rate,
    q=dividend_yield,
    sigma=rolling_vol,
    T=T
)

call_K2 = black_scholes_call(
    S=close_data,
    K=K2,
    r=risk_free_rate,
    q=dividend_yield,
    sigma=rolling_vol,
    T=T
)

# Net premium paid for the bull call spread
net_spread_premium = call_K1 - call_K2

# Payoff at maturity
spread_payoff = (
    (ST - K1).clip(lower=0)
    - (ST - K2).clip(lower=0)
)

# Return on option premium
call_spread_return_pct = ((spread_payoff - net_spread_premium) / net_spread_premium) * 100

# Clean final data
call_spread_return_pct = call_spread_return_pct.iloc[vol_window:-tenor_days]
net_spread_premium = net_spread_premium.iloc[vol_window:-tenor_days]
spread_payoff = spread_payoff.iloc[vol_window:-tenor_days]

print("This is a BULL CALL SPREAD Option using daily Black-Scholes pricing")

# Summary statistics
print(call_spread_return_pct.describe())

# Line chart
fig_line = px.line(
    data_frame=call_spread_return_pct,
    title="Bull Call Spread Return % using Daily Black-Scholes Premium"
)
fig_line.show()

# Boxplot
fig_box = px.box(
    data_frame=call_spread_return_pct,
    title="Bull Call Spread Return % Distribution"
)
fig_box.show()

# Histogram
fig_hist = px.histogram(
    data_frame=call_spread_return_pct,
    nbins=20,
    barmode='group',
    title="Bull Call Spread Return % Histogram"
)
fig_hist.show()

# Optional: premium chart
fig_premium = px.line(
    data_frame=net_spread_premium,
    title="Daily Black-Scholes Net Spread Premium"
)
fig_premium.show()

# Return % line chart
fig_return = px.line(
    data_frame=call_spread_return_pct,
    title="Bull Call Spread Return % using Daily Black-Scholes Premium",
    labels={
        "value": "Return (%)",
        "Date": "Date",
        "variable": "Ticker"
    }
)
fig_return.show()
